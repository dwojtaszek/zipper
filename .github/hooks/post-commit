#!/bin/bash
# Post-commit hook — promotes the pre-commit "pending" sentinel into the
# "ok" marker the pre-push hook uses to skip redundant unit tests.
#
# Handshake (prevents --no-verify from granting a free skip):
#   pre-commit (on success) → writes pre-commit.pending
#   post-commit             → promotes pending → pre-commit.ok (new HEAD hash)
#   pre-push                → reads pre-commit.ok, skips unit tests if same HEAD and <10 min old
#
# A pending file older than 10 minutes is considered stale and ignored.
# Runs AFTER the new commit object exists, so git rev-parse HEAD returns
# the newly-created commit (which is exactly what pre-push will see).
#
# Works in both regular repositories and worktrees: uses `git rev-parse
# --git-path` so the marker lives next to the active hook's git dir.

set -u

SENTINEL_MAX_AGE=600

MARKER_DIR=$(git rev-parse --git-path zipper-hooks 2>/dev/null || echo "")
if [[ -z "$MARKER_DIR" ]]; then
    exit 0
fi

PENDING="$MARKER_DIR/pre-commit.pending"
OK="$MARKER_DIR/pre-commit.ok"

# Always clear any stale ok marker so we never grant skip credit from an
# earlier run that didn't produce a fresh pending sentinel.
rm -f "$OK" 2>/dev/null || true

# If pre-commit didn't run (e.g. --no-verify), there's no pending sentinel.
if [[ ! -f "$PENDING" ]]; then
    exit 0
fi

PENDING_TS=$(grep '^timestamp=' "$PENDING" 2>/dev/null | cut -d= -f2)
NOW=$(date +%s)
if [[ -z "$PENDING_TS" ]] || (( NOW - PENDING_TS > SENTINEL_MAX_AGE )); then
    rm -f "$PENDING" 2>/dev/null || true
    exit 0
fi

HEAD_HASH=$(git rev-parse HEAD 2>/dev/null || echo "")
if [[ -z "$HEAD_HASH" ]]; then
    rm -f "$PENDING" 2>/dev/null || true
    exit 0
fi

mkdir -p "$MARKER_DIR" 2>/dev/null || exit 0
printf 'timestamp=%s\nhead=%s\n' "$NOW" "$HEAD_HASH" > "$OK" 2>/dev/null || true
rm -f "$PENDING" 2>/dev/null || true

exit 0
